# Environment Configuration
NODE_ENV=development

# Server Ports (for local development)
FRONTEND_PORT=8080
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

# SECRETS - DO NOT COMMIT TO GITHUB
# Web3Forms API Key (Get from https://web3forms.com)
WEB3FORMS_ACCESS_KEY=YOUR_WEB3FORMS_ACCESS_KEY_HERE

# Form Email Configuration (Where form submissions are sent)
WEB3FORMS_EMAIL=your-email@gmail.com

# Note: For frontend deployment, copy WEB3FORMS_EMAIL value to
# frontend/js/config.js line 69 (WEB3FORMS.EMAIL)
# All other business information is already in config.js
#
# To set up:
# 1. Copy this file to .env
# 2. Add your Web3Forms access key from https://web3forms.com
# 3. Add your email address for receiving forms
# 4. Copy the email to frontend/js/config.js for deployment
